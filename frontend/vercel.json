{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    {
      "source": "/((?!api/|assets/|favicon.ico|sitemap.xml|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
